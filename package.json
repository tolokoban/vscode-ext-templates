{
    "name": "tolokoban-templates",
    "displayName": "tolokoban-templates",
    "description": "Quick customizable templates available in the file epxlorer",
    "version": "0.5.0",
    "publisher": "tolokoban",
    "repository": {
        "type": "git",
        "url": "https://github.com/tolokoban/vscode-ext-templates"
    },
    "icon": "logo.jpg",
    "engines": {
        "vscode": "^1.110.0"
    },
    "categories": [
        "Other"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "tolokoban-templates.applyTemplate",
                "title": "Templates: apply (Tlk)"
            },
            {
                "command": "tolokoban-templates.editTemplates",
                "title": "Templates: edit (Tlk)"
            },
            {
                "command": "tolokoban-templates.license",
                "title": "Templates: license (Tlk)"
            }
        ],
        "submenus": [
            {
                "id": "tolokoban-templates.submenu",
                "label": "Tolokoban"
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "when": "explorerResourceIsFolder",
                    "submenu": "tolokoban-templates.submenu",
                    "group": "YourGroup@1"
                }
            ],
            "tolokoban-templates.submenu": [
                {
                    "command": "tolokoban-templates.applyTemplate"
                },
                {
                    "command": "tolokoban-templates.editTemplates"
                },
                {
                    "command": "tolokoban-templates.license"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "rspack build --mode production --devtool hidden-source-map",
        "compile": "rspack build",
        "watch": "rspack build --watch",
        "package": "vsce package",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@rspack/cli": "^1.3.0",
        "@rspack/core": "^1.3.0",
        "@tolokoban/type-guards": "^0.9.0",
        "@types/glob": "^9.0.0",
        "@types/js-yaml": "^4.0.9",
        "@types/json5": "^2.2.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "22.10.5",
        "@types/vscode": "^1.110.0",
        "@typescript-eslint/eslint-plugin": "^6.21.0",
        "@typescript-eslint/parser": "^6.21.0",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.7.1",
        "eslint": "^8.57.1",
        "glob": "^12.0.0",
        "mocha": "^11.0.1",
        "typescript": "^5.7.2"
    },
    "dependencies": {
        "json5": "^2.2.3"
    }
}